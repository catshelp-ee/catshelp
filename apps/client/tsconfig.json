{
    "compilerOptions": {
        "jsx": "react-jsx",
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "paths": {
            "@api/*" : [
                "./src/services/api/*"
            ],
            "@translations/*": [
                "./src/translations/*"
            ],
            "@config/*": [
                "./src/config/*"
            ],
            "@app-types/*": [
                "./src/types/*"
            ],
            "@interfaces/*": [
                "./src/interfaces/*"
            ],
            "@components/*": [
                "./src/components/*"
            ],
            "@analytics/*": [
                "./src/analytics/*"
            ],
            "@assets/*": [
                "./src/assets/*"
            ],
            "@context/*": [
                "./src/context/*"
            ],
            "@pages/*": [
                "./src/pages/*"
            ],
            "@style/*": [
                "./src/style/*"
            ],
            "@utils/*": [
                "./src/utils/*"
            ],
            "@hooks/*": [
                "./src/hooks/*"
            ],
            "@server/*": [
                "../server/src/*"
            ],
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "server"
    ]
}