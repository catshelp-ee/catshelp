{
    "name": "catshelp",
    "packageManager": "npm@11.13.0",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "lint": "turbo run lint",
        "lint:fix": "turbo run lint:fix",
        "build": "turbo run build --force",
        "client": "npm run dev:vite -w @catshelp/client"
    },
    "dependencies": {
        "@nestjs/schedule": "^6.1.3",
        "cache-manager": "^7.2.8",
        "esbuild": "^0.28.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.5.0",
        "prettier": "^3.8.3",
        "turbo": "^2.9.6",
        "typescript-eslint": "^8.59.1"
    }
}
