{
    "name": "catshelp",
    "packageManager": "npm@11.12.1",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "build:server": "turbo run build --filter=@catshelp/server --force",
        "build": "turbo run build --force",
        "start:prod": "node build/server/main.js",
        "client": "npm run dev:vite -w @catshelp/client",
        "server": "npm run start:dev -w @catshelp/server",
        "typeorm": "ts-node ./node_modules/typeorm/cli.js",
        "migration:run:dev": "ts-node -r tsconfig-paths/register --project apps/server/tsconfig.json ./node_modules/typeorm/cli.js migration:run -d apps/server/src/data-source.ts ------- DOES NOT WORK ATM -------", 
        "migration:run": "node ./node_modules/typeorm/cli.js migration:run -d build/server/data-source.js",
        "migration:create:windows": "npm run typeorm -- migration:create apps/server/src/migrations/%npm_config_name%",
        "migration:create:unix": "npm run typeorm -- migration:create apps/server/src/migrations/$npm_config_name"
    },
    "dependencies": {
        "@nestjs/schedule": "^6.1.3",
        "esbuild": "^0.28.0"
    },
    "devDependencies": {
        "turbo": "^2.9.6"
    }
}